# Example only. Do not put real secrets in git.
# Put real values in owner-inputs.local.env or in your password manager.

# Hetzner Cloud
HCLOUD_PROJECT_NAME="smartrest-prod-v2"
HCLOUD_TOKEN="CHANGE_ME_READ_WRITE_TOKEN"
HCLOUD_LOCATION="fsn1"
HCLOUD_NETWORK_CIDR="10.10.0.0/16"
HCLOUD_SUBNET_CIDR="10.10.1.0/24"

# Terraform remote state: Hetzner Object Storage S3-compatible backend
TFSTATE_BUCKET="hetzner-prod-infra-tfstate"
TFSTATE_KEY="prod/terraform.tfstate"
TFSTATE_REGION="eu-central-1"
TFSTATE_ENDPOINT="https://fsn1.your-objectstorage.com"
AWS_ACCESS_KEY_ID="CHANGE_ME_OBJECT_STORAGE_ACCESS_KEY"
AWS_SECRET_ACCESS_KEY="CHANGE_ME_OBJECT_STORAGE_SECRET_KEY"

# SSH access
SSH_PUBLIC_KEY_PATH="~/.ssh/hetzner_prod_v2.pub"
SSH_PRIVATE_KEY_PATH="~/.ssh/hetzner_prod_v2"
ALLOWED_SSH_IP="203.0.113.5/32"

# Kubernetes / K3s
K3S_TOKEN="CHANGE_ME_GENERATE_WITH_OPENSSL_RAND_HEX_32"
K3S_VERSION="v1.35.6+k3s1"
CONTROL_PLANE_COUNT="3"
WORKER_COUNT="4"

# Git / GitOps
INFRA_GIT_URL="git@github.com:ORG_OR_USER/hetzner-prod-infra.git"
INFRA_GIT_BRANCH="main"
GITHUB_OWNER="ORG_OR_USER"
GITHUB_REPO="hetzner-prod-infra"
FLUX_BOOTSTRAP_TOKEN="CHANGE_ME_GITHUB_TOKEN_FOR_FLUX"
GITOPS_TOKEN="CHANGE_ME_FINE_GRAINED_TOKEN_FOR_APP_CI"

# DNS / domains
DNS_PROVIDER="cloudflare"
LB_PUBLIC_IP_AFTER_TERRAFORM="203.0.113.10"
TEST_PROD_DOMAIN="test-prod.example.com"
SMART_REST_DOMAIN="api.smart-rest.example.com"
FITNESS_DOMAIN="fitness.example.com"
BEAUTY_DOMAIN="beauty.example.com"
MOOTQ_DOMAIN="mootq.example.com"

# Container registry
REGISTRY_HOST="ghcr.io"
REGISTRY_USERNAME="CHANGE_ME"
REGISTRY_TOKEN="CHANGE_ME"
SMART_REST_IMAGE="ghcr.io/ORG/smart-rest"
FITNESS_IMAGE="ghcr.io/ORG/fitness"
BEAUTY_IMAGE="ghcr.io/ORG/beauty"
MOOTQ_IMAGE="ghcr.io/ORG/mootq-v2"

# Application repositories
SMART_REST_GIT_URL="git@github.com:ORG/smart-rest.git"
FITNESS_GIT_URL="git@github.com:ORG/fitness.git"
BEAUTY_GIT_URL="git@github.com:ORG/beauty.git"
MOOTQ_GIT_URL="git@github.com:ORG/mootq-v2.git"

# Database / Redis decisions
MARIADB_ROOT_PASSWORD="CHANGE_ME_STORE_OUTSIDE_GIT"
SMART_REST_DB_NAME="smartrest"
FITNESS_DB_NAME="fitness"
BEAUTY_DB_NAME="beauty"
MOOTQ_DB_NAME="mootq"
REDIS_MODE="none"

# Monitoring / alerts
ALERT_CHANNEL="telegram"
ALERT_WEBHOOK_OR_BOT_TOKEN="CHANGE_ME_STORE_OUTSIDE_GIT"
ALERT_RECIPIENTS="CHANGE_ME"
